{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "lockFileMaintenance": {
    "enabled": true
  },
  "packageRules": [
    {
      "groupName": "sentry",
      "matchPackageNames": ["@sentry/**"]
    },
    {
      "groupName": "svelte",
      "matchPackageNames": ["@sveltejs/**", "svelte", "svelte-check"]
    },
    {
      "groupName": "eslint and prettier",
      "matchPackageNames": [
        "@babel/eslint-parser",
        "@eslint/js",
        "eslint",
        "eslint-config-prettier",
        "eslint-plugin-svelte",
        "espree",
        "globals",
        "prettier",
        "prettier-plugin-svelte",
        "typescript-eslint"
      ]
    },
    {
      "groupName": "vite and plugins",
      "matchPackageNames": [
        "@sveltejs/vite-plugin-svelte",
        "@vite-pwa/assets-generator",
        "@vite-pwa/sveltekit",
        "vite",
        "vite-plugin-pwa"
      ]
    }
  ]
}
